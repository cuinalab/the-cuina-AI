<style>
/* ══════════════════════════════════════
   FOOTER The Cuina AI
══════════════════════════════════════ */

.tc-footer {
  position: relative;
  background-color: #111214;
  color: #fff;
  padding: 80px 0 40px;
  font-family: 'Lato', sans-serif;
  overflow: hidden;
}

/* Textura de fondo orgánica */
.tc-footer-bg {
  position: absolute;
  inset: 0;
  background-color: #111214;
  background-image: url('/assets/images/helix_assimmetry-invert.png');
  background-repeat: no-repeat;
  background-size: 1100px auto;
  background-position: 54% 0;
  pointer-events: none;
}

/* Línea superior */
.tc-footer::before {
  content: "";
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 1px;
  background: rgba(255,255,255,0.07);
}

.tc-footer-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}

/* ── FILA 1: CTA + Nav ── */
.tc-footer-row-top {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  padding-bottom: 64px;
}

.tc-footer-cta {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.tc-footer-heading {
  font-size: clamp(2rem, 5.5vw, 3rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1;
  color: #fff;
  margin: 0 0 20px;
}

.tc-footer-email {
  display: inline-block;
  font-size: 1rem;
  font-weight: 400;
  color: rgba(255,255,255,0.8);
  text-decoration: underline;
  text-underline-offset: 4px;
  text-decoration-color: rgba(255,255,255,0.25);
  transition: color 0.2s, text-decoration-color 0.2s;
  width: fit-content;
}

.tc-footer-email:hover {
  color: #fff;
  text-decoration-color: rgba(255,255,255,0.7);
}

.tc-footer-tel {
  display: inline-block;
  font-size: 1rem;
  font-weight: 400;
  color: rgba(255,255,255,0.8);
  text-decoration: none;
  transition: color 0.2s;
  width: fit-content;
}

.tc-footer-tel:hover { color: #fff; }

/* Nav: 2 columnas */
.tc-footer-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 24px;
  align-content: start;
  padding-top: 4px;
}

.tc-footer-nav-col {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
}

.tc-footer-nav-col li a {
  display: block;
  height: auto;
  font-size: 1rem;
  font-weight: 400;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  padding: 9px 0;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  transition: color 0.2s;
}

.tc-footer-nav-col li:first-child a {
  border-top: 1px solid rgba(255,255,255,0.07);
}

.tc-footer-nav-col li a:hover { color: #fff; }

/* ── FILA 2: Oficinas ── */
.tc-footer-row-offices {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  padding-bottom: 64px;
}

.tc-footer-offices-spacer { /* columna vacía izquierda */ }

.tc-footer-offices {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px 12px;
}

.tc-footer-office {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.tc-office-city {
  font-size: 0.9rem;
  font-weight: 700;
  color: #fff;
}

.tc-office-address {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.4);
  line-height: 1.6;
}

/* ── FILA 3: Bottom ── */
.tc-footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: 32px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}

.tc-footer-social {
  display: flex;
  align-items: center;
  gap: 18px;
}

.tc-footer-social a {
  color: rgba(255,255,255,0.38);
  display: flex;
  align-items: center;
  transition: color 0.2s;
}

.tc-footer-social a:hover { color: #fff; }

.tc-footer-bottom-right {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.tc-footer-copy {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.38);
}

.tc-footer-bottom-right a {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.38);
  text-decoration: none;
  transition: color 0.2s;
}

.tc-footer-bottom-right a:hover { color: #fff; }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .tc-footer-row-top,
  .tc-footer-row-offices {
    grid-template-columns: 1fr;
    gap: 36px;
  }

  .tc-footer-offices-spacer { display: none; }

  .tc-footer-offices {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 540px) {
  .tc-footer-heading { font-size: 2.6rem; }

  .tc-footer-offices {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .tc-footer-bottom {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .tc-footer-nav {
    grid-template-columns: 1fr;
  }
}
</style>