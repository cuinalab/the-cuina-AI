---
import Base from '../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": "https://www.thecuina.com/sobre-the-cuina",
      "url": "https://www.thecuina.com/sobre-the-cuina",
      "name": "Sobre The Cuina AI · Consultora Estratégica de Inteligencia Artificial",
      "description": "Conoce a The Cuina AI, la consultora estratégica de IA que acompaña a empresas a adoptar inteligencia artificial con impacto real en negocio.",
      "publisher": { "@id": "https://www.thecuina.com/#sobre-the-cuina" }
    },
    {
      "@type": "Person",
      "@id": "https://www.thecuina.com/#marco-milanovic",
      "name": "Marco Milanovic",
      "jobTitle": "CEO & Cofounder",
      "worksFor": { "@id": "https://www.thecuina.com/#sobre-the-cuina" },
      "image": "https://www.thecuina.com/assets/images/team/founder-marco-milanovic.jpg"
    },
    {
      "@type": "Person",
      "@id": "https://www.thecuina.com/#gavrilo-markovic",
      "name": "Gavrilo Markovic",
      "jobTitle": "Chief Creativity Officer & Cofounder",
      "worksFor": { "@id": "https://www.thecuina.com/#sobre-the-cuina" },
      "image": "https://www.thecuina.com/assets/images/team/founder-gavrilo_markovic.jpg"
    }
  ]
};
---

<Base
  title="Sobre The Cuina AI · Consultora Estratégica de Inteligencia Artificial"
  description="The Cuina AI es la consultora de IA que trabaja desde el negocio, no desde la tecnología. Conoce al equipo, nuestra visión y cómo implementamos IA con impacto real."
  schema={schema}
>

<style>
  /* ── SOBRE PAGE: LIGHT THEME ── */
  .sobre-page {
    background: #fff;
    color: #111;
  }

  /* HERO EDITORIAL */
  .sobre-hero {
    background: #fff;
    padding: 160px 24px 80px;
    text-align: center;
  }

  .sobre-hero .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .sobre-hero h1 {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #0d0d0d;
    max-width: 820px;
    margin: 0 auto 28px;
  }

  .sobre-hero h1 em {
    font-style: normal;
    color: var(--accent);
  }

  .sobre-hero p {
    font-size: 1.15rem;
    color: #555;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.75;
    font-weight: 400;
  }

  /* FOTO EDITORIAL ANCHA */
  .editorial-img {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    display: block;
  }

  /* SECCIÓN DOS COLUMNAS TEXTO */
  .two-col-text {
    background: #fff;
    padding: 100px 0;
  }

  .two-col-text .inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .two-col-text h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: #0d0d0d;
    line-height: 1.15;
  }

  .two-col-text .right p {
    font-size: 1rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 20px;
    font-weight: 400;
  }

  .two-col-text .tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  /* VISION CLARA */
  .vision-clara {
    background: #f7f9f8;
    padding: 100px 0;
  }

  .vision-clara .inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: center;
  }

  .vision-clara h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: #0d0d0d;
    line-height: 1.15;
  }

  .vision-clara .tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .vision-clara p {
    font-size: 1rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 20px;
    font-weight: 400;
  }

  .vision-stat {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin-top: 16px;
  }

  .stat-item {
    border-left: 3px solid var(--accent);
    padding-left: 20px;
  }

  .stat-item strong {
    display: block;
    font-size: 2rem;
    font-weight: 900;
    color: #0d0d0d;
    letter-spacing: -0.02em;
  }

  .stat-item span {
    font-size: 0.9rem;
    color: #666;
    font-weight: 400;
  }

  /* PRINCIPIOS */
  .principios {
    background: #fff;
    padding: 100px 0;
  }

  .principios-header {
    max-width: 1140px;
    margin: 0 auto 64px;
    padding: 0 24px;
  }

  .principios-header .tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .principios-header h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: #0d0d0d;
  }

  .principios-grid {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    background: #fff;
  }

  .principio-item {
    background: #fff;
    padding: 48px;
  }

  .principio-num {
    font-size: 2.4rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .principio-item h3 {
    font-size: 1.3rem;
    font-weight: 900;
    color: #0d0d0d;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }

  .principio-item p {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.75;
    font-weight: 400;
  }

  /* FOUNDERS */
  .founders {
    background: #f7f9f8;
    padding: 100px 0;
  }

  .founders-header {
    max-width: 1140px;
    margin: 0 auto 64px;
    padding: 0 24px;
    text-align: center;
  }

  .founders-header .tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .founders-header h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: #0d0d0d;
  }

  .founder-card {
    max-width: 1140px;
    margin: 0 auto 80px;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 80px;
    align-items: start;
  }

  .founder-card.reverse {
    grid-template-columns: 1fr 360px;
  }

  .founder-card.reverse .founder-img {
    order: 2;
  }

  .founder-card.reverse .founder-text {
    order: 1;
  }

  .founder-img {
    position: relative;
  }

  .founder-img img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    border-radius: 20px;
    display: block;
  }

  .founder-role {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .founder-text h3 {
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 900;
    color: #0d0d0d;
    letter-spacing: -0.025em;
    margin-bottom: 24px;
  }

  .founder-text p {
    font-size: 1rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 18px;
    font-weight: 400;
  }

  .founder-divider {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    border: none;
    border-top: 1px solid #e0e5e3;
    margin-bottom: 80px;
  }

  /* METODOLOGÍA CLARA */
  .metodo-clara {
    background: #0d0d0d;
    padding: 100px 0;
    color: #f0f0f0;
  }

  .metodo-clara .inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .metodo-clara .tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .metodo-clara h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: #fff;
    margin-bottom: 64px;
  }

  .metodo-clara-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: #222;
  }

  .metodo-clara-step {
    background: #0d0d0d;
    padding: 48px 40px;
  }

  .metodo-clara-step .num {
    font-size: 3rem;
    font-weight: 900;
    color: var(--accent);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 24px;
    opacity: 1;
  }

  .metodo-clara-step h3 {
    font-size: 1.5rem;
    font-weight: 900;
    color: #fff;
    margin-bottom: 16px;
  }

  .metodo-clara-step p {
    font-size: 0.90rem;
    color: var(--text);
    line-height: 1.75;
    font-weight: 300;
  }

  /* CTA CLARA */
  .cta-clara {
    background: #fff;
    padding: 120px 24px;
    text-align: center;
  }

  .cta-clara .tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .cta-clara h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: #0d0d0d;
    max-width: 700px;
    margin: 0 auto 20px;
    line-height: 1.1;
  }

  .cta-clara p {
    font-size: 1.05rem;
    color: #555;
    max-width: 520px;
    margin: 0 auto 40px;
    line-height: 1.75;
    font-weight: 400;
  }

  .btn-cta-dark {
    background: linear-gradient(
    180deg,
    rgba(30,40,60,0.65) 0%,
    rgba(20,25,40,0.95) 100%
  );
    color: #fff;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .btn-cta-dark:hover {
    background:linear-gradient(
    180deg,
    rgba(35, 36, 38, 0.85) 0%,
    rgba(20,25,40,0.99) 100%);
    transform: translateY(-1px);
  }

  .btn-outline-dark {
    background:linear-gradient(
    180deg,
    rgba(247, 247, 247, 0.35) 0%,
    rgba(183, 180, 180, 0.55) 100%);
    color: #0d0d0d;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: 8px;
    border: 1.5px solid #ccc;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    margin-left: 12px;
  }

  .btn-outline-dark:hover {
    border-color: #0d0d0d;
    color: #0d0d0d;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .two-col-text .inner { grid-template-columns: 1fr; gap: 32px; }
    .vision-clara .inner { grid-template-columns: 1fr; gap: 48px; }
    .principios-grid { grid-template-columns: 1fr; }
    .founder-card { grid-template-columns: 1fr; gap: 40px; }
    .founder-card.reverse .founder-img { order: 0; }
    .founder-card.reverse .founder-text { order: 0; }
    .metodo-clara-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="sobre-page">

  <!-- HERO -->
  <section class="sobre-hero">
    <p class="eyebrow">Sobre The Cuina AI</p>
    <h1>La IA que <em>transforma</em><br>empieza por la estrategia</h1>
    <p>No somos una empresa de tecnología. Somos el socio estratégico que traduce la inteligencia artificial en decisiones de negocio, eficiencia operativa y ventaja competitiva real.</p>
  </section>

  <!-- FOTO EDITORIAL -->
  <img
    src="/assets/images/the_cuina_AI_office-intelligent.jpg"
    alt="Equipo The Cuina AI trabajando en estrategia de inteligencia artificial en sus oficinas"
    class="editorial-img"
    width="1440"
    height="520"
  >

  <!-- QUÉ ES THE CUINA -->
  <section class="two-col-text" id="que-es-the-cuina">
    <div class="inner fade-in">
      <div class="left">
        <span class="tag">Quiénes somos</span>
        <h2>Una consultora de IA<br>que habla tu idioma</h2>
      </div>
      <div class="right">
        <p>The Cuina AI nació con una convicción clara: la inteligencia artificial solo tiene valor cuando genera impacto medible en el negocio. No en demos. No en pilotos eternos. En resultados reales, vinculados a métricas concretas.</p>
        <p>Trabajamos con empresas medianas y PYMEs que quieren adoptar IA de forma estratégica — sin perder el tiempo en tecnología que no encaja con sus procesos ni en soluciones genéricas que no escalan.</p>
        <p>Cada proyecto empieza por entender cómo funciona tu negocio. Luego viene la IA.</p>
      </div>
    </div>
  </section>

  <!-- NUESTRA VISIÓN -->
  <section class="vision-clara" id="nuestra-vision">
    <div class="inner fade-in">
      <div>
        <span class="tag">Nuestra visión</span>
        <h2>Un mundo donde la IA<br>amplifica el talento humano</h2>
        <div class="vision-stat">
          <div class="stat-item">
            <strong>30 días</strong>
            <span>Primeros resultados medibles con el Sprint IA</span>
          </div>
          <div class="stat-item">
            <strong>60–90 días</strong>
            <span>Tiempo medio de recuperación de la inversión</span>
          </div>
          <div class="stat-item">
            <strong>0 permanencias</strong>
            <span>Trabajamos sin contratos de permanencia</span>
          </div>
        </div>
      </div>
      <div>
        <p>Creemos que la inteligencia artificial es la mayor palanca de competitividad empresarial de nuestra generación. Pero solo si se adopta con criterio.</p>
        <p>Nuestra misión es que cada empresa con la que trabajamos salga más rápida, más rentable y con equipos más enfocados en lo que realmente importa: crear valor, no gestionar tareas repetitivas.</p>
        <p>No implementamos tecnología por implementar. Cada agente, cada automatización y cada decisión estratégica está vinculada a una métrica de negocio. Si no genera impacto tangible, no lo hacemos.</p>
      </div>
    </div>
  </section>

  <!-- CÓMO PENSAMOS LA IA -->
  <section class="principios" id="como-pensamos-la-ia">
    <div class="principios-header fade-in">
      <span class="tag">Nuestro enfoque</span>
      <h2>Los principios que guían<br>cada decisión que tomamos</h2>
    </div>
    <div class="principios-grid fade-in">
      <div class="principio-item">
        <div class="principio-num">01</div>
        <h3>Negocio primero,<br>tecnología después</h3>
        <p>Antes de proponer ninguna solución, entendemos tus procesos, tus fricciones y tus objetivos. La IA que implementamos resuelve problemas reales, no problemas teóricos.</p>
      </div>
      <div class="principio-item">
        <div class="principio-num">02</div>
        <h3>Impacto medible<br>o no se implementa</h3>
        <p>Cada proyecto está vinculado a una métrica clara: margen, productividad, tiempo ahorrado o ingresos generados. Si no podemos medir el impacto, no lo consideramos un éxito.</p>
      </div>
      <div class="principio-item">
        <div class="principio-num">03</div>
        <h3>Velocidad sin<br>sacrificar solidez</h3>
        <p>Entregamos resultados en 30 días porque hemos diseñado un método que elimina todo lo que no aporta valor. Sin fases de análisis interminables ni pilotos eternos.</p>
      </div>
      <div class="principio-item">
        <div class="principio-num">04</div>
        <h3>Adoptamos contigo,<br>no para ti</h3>
        <p>Tu equipo aprende y entiende cada implementación. No creamos dependencias tecnológicas. Creamos capacidades internas que tu organización puede sostener y escalar de forma autónoma.</p>
      </div>
    </div>
  </section>

  <!-- FOUNDERS -->
  <section class="founders" id="founders">
    <div class="founders-header fade-in">
      <span class="tag">El equipo fundador</span>
      <h2>Las personas detrás<br>de The Cuina AI</h2>
    </div>

    <!-- MARCO -->
    <div class="founder-card fade-in">
      <div class="founder-img">
        <img
          src="/assets/images/team/founder-marco-milanovic.jpg"
          alt="Marco Milanovic, CEO y Cofundador de The Cuina AI"
          width="360"
          height="480"
        >
      </div>
      <div class="founder-text">
        <div class="founder-role">CEO & Cofounder</div>
        <h3>Marco Milanovic</h3>
        <p>Marco lidera la visión estratégica de The Cuina AI. Con una trayectoria construida en la intersección entre negocio y tecnología, ha acompañado a organizaciones de distintos sectores a transformar sus operaciones con criterio y foco en resultados.</p>
        <p>Su obsesión es una: que cada euro invertido en IA genere un retorno tangible y medible. Bajo su dirección, The Cuina AI ha desarrollado el método ADA, un framework que convierte la incertidumbre sobre la IA en pasos concretos, rápidos y orientados al impacto.</p>
        <p>Cree que la IA más poderosa no es la más sofisticada, sino la que resuelve el problema correcto en el momento correcto.</p>
        <a href="https://www.linkedin.com/in/marcomilanovic/" target="_blank" rel="noopener noreferrer" class="btn-outline-dark" style="margin-top:8px;">LinkedIn →</a>
      </div>
    </div>

    <hr class="founder-divider">

    <!-- GAVRILO -->
    <div class="founder-card reverse fade-in">
      <div class="founder-text">
        <div class="founder-role">Chief Creativity Officer & Cofounder</div>
        <h3>Gavrilo Markovic</h3>
        <p>Gavrilo es el arquitecto creativo de The Cuina AI. Su rol va mucho más allá del diseño: es quien traduce conceptos complejos de inteligencia artificial en propuestas de valor claras, memorables y orientadas a las personas.</p>
        <p>Con una visión que combina pensamiento estratégico y sensibilidad creativa, Gavrilo es responsable de que cada solución que desarrollamos no solo funcione, sino que sea adoptada y comprendida por los equipos que la usan.</p>
        <p>Para él, la mejor implementación de IA es la que el equipo abraza como propia desde el primer día.</p>
        <a href="https://www.linkedin.com/in/gavrilo-markovic-jankovic-414785287/" target="_blank" rel="noopener noreferrer" class="btn-outline-dark" style="margin-top:8px;">LinkedIn →</a>
      </div>
      <div class="founder-img">
        <img
          src="/assets/images/team/founder-gavrilo_markovic.jpg"
          alt="Gavrilo Markovic, Chief Creativity Officer y Cofundador de The Cuina AI"
          width="360"
          height="480"
        >
      </div>
    </div>

  </section>

  <!-- METODOLOGÍA -->
  <section class="metodo-clara" id="metodologia">
    <div class="inner">
      <div class="fade-in">
        <span class="tag">Nuestra metodología</span>
        <h2>El método ADA: de la<br>incertidumbre al impacto</h2>
      </div>
      <div class="metodo-clara-grid fade-in">
        <div class="metodo-clara-step">
          <div class="num">01</div>
          <h3>Aware</h3>
          <p>Analizamos tu organización para detectar los procesos con mayor potencial de mejora, las fricciones operativas que más coste generan y los quick wins donde la IA puede generar impacto medible desde el primer día.</p>
        </div>
        <div class="metodo-clara-step">
          <div class="num">02</div>
          <h3>Define</h3>
          <p>Priorizamos y construimos un roadmap claro. Convertimos la incertidumbre sobre la IA en pasos concretos, seguros y enfocados al ROI. Sabes exactamente qué se implementa, cuándo y qué resultado esperamos.</p>
        </div>
        <div class="metodo-clara-step">
          <div class="num">03</div>
          <h3>Activate</h3>
          <p>Implementamos, medimos y escalamos. Probamos rápido, validamos resultados y solo escalamos lo que funciona. Tu equipo queda formado y la solución integrada en los procesos reales de la organización.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-clara" id="contacto">
    <span class="tag">¿Trabajamos juntos?</span>
    <h2>Listos para escucharte</h2>
    <p>Si buscas una consultora de IA que trabaje desde el negocio, mida el impacto de cada implementación y entregue resultados en 30 días, estamos listos.</p>
    <div>
      <a href="/#contacto" class="btn-cta-dark">Solicita una llamada gratuita →</a>
      <a href="/consultoria-inteligencia-artificial" class="btn-outline-dark">Ver servicios</a>
    </div>
  </section>

</div>

</Base>