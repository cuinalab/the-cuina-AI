---
import Base from '../layouts/Base.astro';
import '../styles/home.css';


const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization", "LocalBusiness"],
      "@id": "https://www.thecuina.com/consultoria-ia-madrid/#sobre-the-cuina",
      "name": "The Cuina AI",
      "alternateName": "The Cuina",
      "url": "https://www.thecuina.com/consultoria-ia-madrid",
      "logo": "https://www.thecuina.com/assets/images/logo_ia_the_cuina.png",
      "description": "Consultora estratégica de Inteligencia Artificial en Madrid. Acompañamos a empresas madrileñas en la adopción de agentes y automatizaciones IA con impacto real en negocio.",
      "telephone": "+34-623-789-247",
      "email": "info@thecuina.com",
      "priceRange": "€€",
      "inLanguage": "es",
      "areaServed": [
        { "@type": "City", "name": "Madrid" },
        { "@type": "City", "name": "Lleida" },
        { "@type": "City", "name": "Zaragoza" },
        { "@type": "Country", "name": "España" }
      ],
      "serviceType": [
        "Consultoría de Inteligencia Artificial en Madrid",
        "Implementación de Agentes IA",
        "Automatización de procesos empresariales con Inteligencia Artificial"
      ],
      "founder": { "@id": "https://www.thecuina.com/#founder" },
      "sameAs": [
        "https://www.instagram.com/thecuina",
        "https://www.linkedin.com/company/thecuina"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://www.thecuina.com/consultoria-ia-madrid",
      "url": "https://www.thecuina.com/consultoria-ia-madrid",
      "name": "The Cuina AI - Consultora de Inteligencia Artificial en Madrid",
      "description": "Impulsa tu negocio con IA en Madrid. En The Cuina AI acompañamos estratégicamente a empresas madrileñas a adoptar soluciones de IA con resultados medibles.",
      "inLanguage": "es",
      "publisher": { "@id": "https://www.thecuina.com/consultoria-ia-madrid/#sobre-the-cuina" }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.thecuina.com/consultoria-ia-madrid/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué estoy perdiendo hoy por no integrar IA en mi empresa de Madrid?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Tiempo, eficiencia y competitividad. En un mercado tan dinámico como Madrid, cada semana sin IA es una semana en la que tu competencia gana velocidad. Los procesos manuales que hoy ocupan horas pueden resolverse en minutos con agentes de IA bien implementados."
          }
        },
        {
          "@type": "Question",
          "name": "¿La IA es solo para grandes empresas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Las PYMEs son las que más se benefician porque el impacto relativo en sus procesos es mayor y los costes de implementación son proporcionales a su tamaño."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo se tarda en implementar la IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nuestro Sprint IA entrega resultados medibles en 30 días. Sin pilotos eternos ni fases de análisis interminables."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta implementar inteligencia artificial en una empresa en Madrid?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El coste depende del caso de uso y la complejidad. En The Cuina AI trabajamos con packs desde un Sprint IA puntual hasta modelos continuos de IA as a Service. La mayoría de clientes en Madrid recuperan la inversión en los primeros 60-90 días."
          }
        },
        {
          "@type": "Question",
          "name": "¿Por qué contratar a The Cuina AI como consultora de IA en Madrid?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Porque trabajamos desde el criterio de negocio, no desde la tecnología. Tenemos presencia en Madrid y conocemos las dinámicas del tejido empresarial local. Cada implementación está vinculada a una métrica clara — margen, productividad o ingresos. Si no genera impacto tangible, no lo implementamos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Trabajáis de forma presencial en Madrid?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Tenemos presencia activa en Madrid y trabajamos tanto de forma presencial como remota con organizaciones de toda España. Nuestro equipo puede reunirse contigo en Madrid para el diagnóstico inicial y los hitos clave del proyecto."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué ROI puedo esperar de un proyecto de IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Típicamente nuestros clientes recuperan la inversión en los primeros 60-90 días gracias a la reducción de tiempo en tareas manuales y la automatización de procesos repetitivos."
          }
        }
      ]
    }
  ]
};
