---
import Base from '../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization", "LocalBusiness"],
      "@id": "https://www.thecuina.com/#sobre-the-cuina",
      "name": "The Cuina AI",
      "alternateName": "The Cuina",
      "url": "https://www.thecuina.com",
      "logo": "https://www.thecuina.com/assets/images/logo_ia_the_cuina.png",
      "description": "Consultora estratégica de Inteligencia Artificial que acompaña a empresas en la adopción de agentes y automatizaciones IA.",
      "telephone": "+34-623-789-247",
      "email": "info@thecuina.com",
      "priceRange": "€€",
      "inLanguage": "es",
      "areaServed": [
        { "@type": "City", "name": "Madrid" },
        { "@type": "City", "name": "Lleida" },
        { "@type": "City", "name": "Zaragoza" },
        { "@type": "Country", "name": "España" }
      ],
      "serviceType": [
        "Consultoría de Inteligencia Artificial",
        "Implementación de Agentes IA",
        "Automatización de procesos empresariales con Inteligencia Artificial"
      ],
      "founder": { "@id": "https://www.thecuina.com/#founder" },
      "sameAs": [
        "https://www.instagram.com/thecuina",
        "https://www.linkedin.com/company/thecuina"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://www.thecuina.com",
      "url": "https://www.thecuina.com",
      "name": "The Cuina AI - Consultora de Inteligencia Artificial",
      "description": "Impulsa tu negocio con IA. En The Cuina AI te acompañamos estratégicamente a entender cómo adoptar soluciones de IA en tu negocio.",
      "inLanguage": "es",
      "publisher": { "@id": "https://www.thecuina.com/#sobre-the-cuina" }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.thecuina.com/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué estoy perdiendo hoy por no integrar IA en mi empresa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Tiempo, eficiencia y competitividad. Cada semana sin IA es una semana en la que tu competencia gana velocidad. Los procesos manuales que hoy ocupan horas pueden resolverse en minutos con agentes de IA bien implementados."
          }
        },
        {
          "@type": "Question",
          "name": "¿La IA es solo para grandes empresas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Las PYMEs son las que más se benefician porque el impacto relativo en sus procesos es mayor y los costes de implementación son proporcionales a su tamaño."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo se tarda en implementar la IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nuestro Sprint IA entrega resultados medibles en 30 días. Sin pilotos eternos ni fases de análisis interminables."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta implementar inteligencia artificial en una empresa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El coste depende del caso de uso y la complejidad. En The Cuina AI trabajamos con packs desde un Sprint IA puntual hasta modelos continuos de IA as a Service. La mayoría de clientes recuperan la inversión en los primeros 60-90 días."
          }
        },
        {
          "@type": "Question",
          "name": "¿Por qué contratar a The Cuina AI como consultora de IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Porque trabajamos desde el criterio de negocio, no desde la tecnología. Cada implementación está vinculada a una métrica clara — margen, productividad o ingresos. Si no genera impacto tangible, no lo implementamos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Dónde trabajáis?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Tenemos presencia en Madrid, Lleida y Zaragoza, pero trabajamos con organizaciones de toda España tanto de forma presencial como remota."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué ROI puedo esperar de un proyecto de IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Típicamente nuestros clientes recuperan la inversión en los primeros 60-90 días gracias a la reducción de tiempo en tareas manuales y la automatización de procesos repetitivos."
          }
        }
      ]
    }
  ]
};
---

<Base
  title="The Cuina AI - Consultora de Inteligencia Artificial | Lleida, Madrid & Zaragoza"
  description="Consultora estratégica especializada en Inteligencia Artificial. Implementamos IA y agentes IA para empresas en Madrid, Lleida, Zaragoza y España."
  schema={schema}
>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-content">
    
    <div class="hero-badge">
      Consultoría estratégica IA
      <span class="solo-desktop">· Madrid · Zaragoza · Lleida</span>
    </div>

    <h1>Implementa Inteligencia Artificial en tu empresa</h1>

    <p>Consultoría estratégica para PYMEs que quieren automatizar procesos, reducir costes operativos y mejorar la toma de decisiones.
    </p>

    <div class="hero-actions">
      <a href="#contacto" class="btn-cta">Solicitar Diagnóstico de IA →</a>
      <a href="#soluciones" class="btn-outline">Beneficios IA en tu negocio</a>
    </div>

  </div>
</section>

<!-- CASOS DE USO -->
<section class="casos" id="casos">
  <div class="container">
    <div class="casos-intro fade-in">
      <div>
        <div class="section-label">NUESTROS AGENTES IA</div>
        <h2 class="section-title">Servicios IA con formato<br>y efectos inspirados en landing</h2>
      </div>
      <p class="section-sub">Arrancamos por fricciones operativas reales: priorizamos, implementamos y medimos impacto para que cada decisión de IA tenga retorno tangible.</p>
    </div>

    <div class="casos-grid fade-in">
      <div class="caso-card">
        <span class="caso-tag">Comercial</span>
        <h3>Sistema de Seguimiento Comercial Inteligente</h3>
        <div class="caso-problem">
          <strong>Problema:</strong>
          Procesos comerciales lentos, muchas horas prospectando y clientes perdidos.
        </div>
        <ul class="caso-list">
          <li>Generación profesional de propuestas</li>
          <li>Emails de seguimiento estratégicos</li>
          <li>Resúmenes automáticos tras reuniones</li>
        </ul>
        <span class="caso-arrow">+</span>
      </div>

      <div class="caso-card">
        <span class="caso-tag">Reuniones</span>
        <h3>Agente IA para Reuniones Que Convierten</h3>
        <div class="caso-problem">
          <strong>Problema:</strong>
          Muchas reuniones que generan buenas ideas pero poca ejecución real.
        </div>
        <ul class="caso-list">
          <li>Notas de la reunión al instante</li>
          <li>Extracción automática de decisiones</li>
          <li>Generación de tareas con responsable</li>
        </ul>
        <span class="caso-arrow">+</span>
      </div>

      <div class="caso-card">
        <span class="caso-tag">Atención cliente</span>
        <h3>Sistema IA de Atención al Cliente 24/7</h3>
        <div class="caso-problem">
          <strong>Problema:</strong>
          WhatsApps constantes, saturación del equipo, respuestas fuera de horario.
        </div>
        <ul class="caso-list">
          <li>Respuestas a preguntas frecuentes</li>
          <li>Confirmaciones y cambios de cita</li>
          <li>Filtrado de urgencias reales</li>
        </ul>
        <span class="caso-arrow">+</span>
      </div>

      <div class="caso-card">
        <span class="caso-tag">Reporting</span>
        <h3>Agente IA para Reporting e Inteligencia de Negocio</h3>
        <div class="caso-problem">
          <strong>Problema:</strong>
          Horas invertidas en reporting manual. Decisiones basadas en intuición.
        </div>
        <ul class="caso-list">
          <li>Consulta de KPIs desde tu móvil</li>
          <li>Resumen diario de indicadores clave</li>
          <li>Alertas ante incidencias críticas</li>
          <li>Informe estratégico mensual</li>
        </ul>
        <span class="caso-arrow">+</span>
      </div>

      <div class="caso-card">
        <span class="caso-tag">Onboarding</span>
        <h3>Sistema IA - Onboarding nuevos clientes</h3>
        <div class="caso-problem">
          <strong>Problema:</strong>
          Alta fricción inicial por el intercambio manual de documentación.
        </div>
        <ul class="caso-list">
          <li>Envío de formulario dinámico</li>
          <li>Validación automática de datos</li>
          <li>Solicitud de documentación faltante</li>
          <li>Generación de ficha interna</li>
        </ul>
        <span class="caso-arrow">+</span>
      </div>

      <div class="caso-card cta-card">
        <div>
          <h3>¿Quieres conocer casos reales para tu negocio?</h3>
          <p style="font-size:0.9rem;color:var(--muted);margin-top:10px;line-height:1.6;font-weight:400;">Analizamos tu negocio y te mostramos qué agentes generan ROI inmediato, cuáles escalar después y cuáles no merece la pena implementar.</p>
        </div>
        <a href="#packs" class="btn-outline" style="margin-top:24px;">Packs Consulting AI</a>
      </div>
    </div>
  </div>
</section>

<!-- SOBRE NOSOTROS -->
<section class="sobre" id="sobre">
  <div class="container">
    <div class="sobre-grid fade-in">
      <div class="sobre-text">
        <div class="section-label">Sobre nosotros</div>
        <h2 class="section-title">The Cuina AI</h2>
        <p>The Cuina AI es una consultora estratégica especializada en convertir Inteligencia Artificial en eficiencia operativa y rentabilidad real. No vendemos tecnología; rediseñamos procesos clave para que las organizaciones liberen tiempo, reduzcan costes y ganen velocidad competitiva en semanas.</p>
        <p>Trabajamos desde el criterio de negocio: cada implementación está vinculada a una métrica clara — margen, productividad o ingresos.</p>
        <p>Formamos parte del ecosistema The Cuina AI, un laboratorio de innovación orientado a impacto y sostenibilidad empresarial. Si no genera impacto tangible, no lo implementamos.</p>
      </div>
      <div class="sobre-img">
        <img src="/assets/images/the_cuina_AI_office-intelligent.jpg" alt="The Cuina AI Team" width="560" height="315">
      </div>
    </div>
  </div>
</section>

<!-- VISIÓN BANNER -->
<div class="vision-banner">
  <div class="container">
    <div class="vision-inner">
      <div class="section-label" style="text-align:center; margin-bottom: 16px;">Nuestra visión</div>
      <p>Empoderar a las empresas del futuro mediante la innovación y el impacto. Queremos impulsar la adopción de la inteligencia artificial en empresas y organizaciones como una capacidad estratégica real, capaz de amplificar el potencial de los equipos y redefinir la propuesta de valor para generar un impacto positivo.</p>
      <a href="#contacto" class="btn-cta" style="margin-top: 32px;">Descubre The Cuina AI →</a>
    </div>
  </div>
</div>

<!-- METODOLOGÍA -->
<section class="metodologia" id="metodologia">
  <div class="container">
    <div class="fade-in">
      <div class="section-label">Nuestra metodología</div>
      <h2 class="section-title">Nuestra forma de adoptar<br>la IA en negocios</h2>
    </div>
    <div class="metodo-grid fade-in">
      <div class="metodo-steps">
        <div class="metodo-step">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3>Aware</h3>
            <p>Analizamos tu organización para detectar procesos, oportunidades y quick wins donde la IA genere impacto medible desde el primer día.</p>
          </div>
        </div>
        <div class="metodo-step">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3>Define</h3>
            <p>Priorizamos, ordenamos y avanzamos con claridad: un roadmap convierte la incertidumbre en pasos concretos, seguros y enfocados al ROI.</p>
          </div>
        </div>
        <div class="metodo-step">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3>Activate</h3>
            <p>Probamos rápido, validamos resultados y escalamos solo lo que funciona, con tu equipo preparado y la estrategia alineada.</p>
          </div>
        </div>
      </div>
      <div class="metodo-visual">
        <div class="triangle-visual">
          <div class="triangle-inner"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PACKS CONSULTING -->
<section class="packs" id="packs">
  <div class="container">
    <div class="fade-in">
      <div class="section-label">Nuestros packs</div>
      <h2 class="section-title">Elige el modelo que<br>encaja con tu empresa</h2>
      <p class="section-sub">Una estructura inspirada en nuestra landing de referencia: comparativa clara, enfoque práctico y visibilidad permanente de cada pack mientras haces scroll.</p>
    </div>

    <div class="packs-table fade-in">
      <div class="pack-row header-row">
        <div class="pack-label">Modelo</div>
        <div class="pack-cell pack-head">
          <h3>Sprint IA</h3>
          <p>Validación rápida con impacto en 30 días.</p>
        </div>
        <div class="pack-cell pack-head">
          <h3>IA as a Service</h3>
          <p>Evolución continua de agentes y procesos.</p>
        </div>
        <div class="pack-cell pack-head">
          <h3>Transformation IA</h3>
          <p>Transformación integral para escalar el negocio.</p>
        </div>
      </div>

      <div class="pack-row">
        <div class="pack-label">Ideal para</div>
        <div class="pack-cell">Empresas que quieren empezar sin riesgo y ver resultados rápidos.</div>
        <div class="pack-cell">Equipos que ya usan IA y necesitan mantener ventaja competitiva.</div>
        <div class="pack-cell">Organizaciones que buscan rediseñar operaciones, ventas y dirección con IA.</div>
      </div>

      <div class="pack-row">
        <div class="pack-label">Incluye</div>
        <div class="pack-cell">
          <ul>
            <li>Diagnóstico de oportunidades</li>
            <li>Implementación de 1-2 agentes IA</li>
            <li>KPIs de impacto en 30 días</li>
          </ul>
        </div>
        <div class="pack-cell">
          <ul>
            <li>Optimización continua mensual</li>
            <li>Nuevos agentes por prioridad</li>
            <li>Mejora de prompts y formación ejecutiva</li>
          </ul>
        </div>
        <div class="pack-cell">
          <ul>
            <li>Roadmap estratégico de IA por áreas</li>
            <li>Automatización end-to-end de procesos críticos</li>
            <li>Acompañamiento a dirección y mandos</li>
          </ul>
        </div>
      </div>

      <div class="pack-row">
        <div class="pack-label">Inversión orientativa</div>
        <div class="pack-cell"><div class="pack-price">Desde 3.900€</div></div>
        <div class="pack-cell"><div class="pack-price">Desde 1.500€/mes</div></div>
        <div class="pack-cell"><div class="pack-price">Proyecto a medida</div></div>
      </div>

      <div class="pack-row">
        <div class="pack-label">Timeline</div>
        <div class="pack-cell"><div class="pack-time">4 semanas</div></div>
        <div class="pack-cell"><div class="pack-time">Servicio recurrente</div></div>
        <div class="pack-cell"><div class="pack-time">8-16 semanas</div></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA BANNER -->
<div class="cta-banner">
  <div class="container">
    <h2>Ready to Optimize?</h2>
    <p>En solo 30 días podrías tener una solución de IA funcionando y con métricas reales.<br><strong>Agenda una llamada gratuita</strong> y te enseñamos el mejor camino para tu negocio.</p>
    <a href="#contacto" class="btn-cta">Contacta con nosotros →</a>
  </div>
</div>

<!-- FAQ -->
<section class="faq" id="faq">
  <div class="container">
    <div class="faq-grid fade-in">
      <div>
        <div class="section-label">FAQ</div>
        <h2 class="section-title">Preguntas más frecuentes</h2>
        <p class="section-sub" style="margin-top:16px;">Descubre las respuestas a tus preguntas sobre la madurez de las soluciones de IA y su preparación.</p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">¿Qué estoy perdiendo hoy por no integrar IA en mi empresa? <span class="faq-arrow">▾</span></button>
          <div class="faq-answer">Tiempo, eficiencia y competitividad. Cada semana sin IA es una semana en la que tu competencia gana velocidad. Los procesos manuales que hoy ocupan horas pueden resolverse en minutos.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question">¿La IA es solo para grandes empresas? <span class="faq-arrow">▾</span></button>
          <div class="faq-answer">No. Las PYMEs son las que más se benefician porque el impacto relativo en sus procesos es mayor y los costes de implementación son proporcionales a su tamaño.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question">¿Cuánto tiempo se tarda en implementar la IA? <span class="faq-arrow">▾</span></button>
          <div class="faq-answer">Nuestro Sprint IA entrega resultados medibles en 30 días. Sin pilotos eternos ni fases de análisis interminables.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question">¿Por qué contratar a theCuina? <span class="faq-arrow">▾</span></button>
          <div class="faq-answer">Porque trabajamos desde el criterio de negocio, no desde la tecnología. Cada implementación está vinculada a una métrica clara. Si no genera impacto tangible, no lo implementamos.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question">¿Imponéis permanencia? <span class="faq-arrow">▾</span></button>
          <div class="faq-answer">No. Trabajamos sin permanencias porque confiamos en que los resultados hablan por sí solos.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question">¿Dónde trabajáis? <span class="faq-arrow">▾</span></button>
          <div class="faq-answer">Tenemos presencia en Madrid, Lleida y Zaragoza, pero trabajamos con organizaciones de toda España tanto de forma presencial como remota.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question">¿Qué ROI puedo esperar de un proyecto de IA? <span class="faq-arrow">▾</span></button>
          <div class="faq-answer">Depende del caso de uso, pero típicamente nuestros clientes recuperan la inversión en los primeros 60-90 días gracias a la reducción de tiempo en tareas manuales.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACTO -->
<section class="contacto" id="contacto">
  <div class="container">
    <div class="contacto-grid fade-in">

      <div class="contacto-info">
        <div class="section-label">Contacto</div>
        <h2 class="section-title">Solicita una <span style="color:var(--accent)">llamada</span></h2>
        <p>Si deseas impulsar tu negocio con IA, completa el formulario y conecta con nosotros. ¡Te acompañamos a dar el siguiente paso!</p>
        <ul class="contacto-features">
          <li>Consultoría de IA 100% personalizada</li>
          <li>Adaptación a los objetivos del negocio</li>
          <li>Enfoque estratégico para maximizar el ROI</li>
        </ul>
      </div>

      <form class="form-grid" id="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label>Nombre *</label>
            <input type="text" name="name" placeholder="Tu nombre" required>
          </div>
          <div class="form-group">
            <label>Organización *</label>
            <input type="text" name="company" placeholder="Tu empresa" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Cargo *</label>
            <input type="text" name="role" placeholder="Tu cargo" required>
          </div>
          <div class="form-group">
            <label>Correo *</label>
            <input type="email" name="email" placeholder="tu@empresa.com" required>
          </div>
        </div>
        <div class="form-group">
          <label>Tu consulta</label>
          <textarea name="message" placeholder="Cuéntanos tu caso..."></textarea>
        </div>
        <input type="text" name="website" style="display:none">
        <button type="submit" class="btn-cta" style="width:100%;justify-content:center;padding:14px;">
          Solicitar llamada
        </button>
      </form>

    </div>
  </div>
</section>

<script>
  document.getElementById("contact-form").addEventListener("submit", async function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    if (formData.get("website")) return;
    const payload = {
      name: formData.get("name"),
      company: formData.get("company"),
      role: formData.get("role"),
      email: formData.get("email"),
      message: formData.get("message"),
      page: window.location.href,
      submittedAt: new Date().toISOString()
    };
    try {
      const response = await fetch("https://n8n.srv1124642.hstgr.cloud/webhook/lead-thecuina", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      if (response.ok) {
        alert("Gracias. Hemos recibido tu solicitud.");
        this.reset();
      } else {
        alert("Ha habido un error. Por favor, inténtalo de nuevo.");
      }
    } catch {
      alert("Ha habido un error de conexión. Por favor, inténtalo de nuevo.");
    }
  });
</script>

</Base>
