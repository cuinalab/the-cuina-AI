---
import Base from '../layouts/Base.astro';
---

<Base
  title="Página no encontrada · The Cuina AI"
  description="La página que buscas no existe. Vuelve a la home de The Cuina AI."
>
  <div class="error-page">
    <div class="error-bg">
      <img src="/assets/images/404.jpg" alt="" class="error-bg-img" />
      <div class="error-overlay" />
    </div>

    <div class="error-content">
      <p class="error-code">404</p>
      <h1 class="error-title">Esta página no existe</h1>
      <p class="error-sub">Puede que la URL haya cambiado o que nunca haya existido.</p>
      <a href="/" class="error-btn">← Volver a home</a>
    </div>
  </div>
</Base>

<style>
  .error-page {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Imagen de fondo */
  .error-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .error-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .error-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.65) 100%
    );
  }

  /* Contenido centrado */
  .error-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .error-code {
    font-family: 'Lato', sans-serif;
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 900;
    line-height: 1;
    margin: 0;
    opacity: 0.15;
    letter-spacing: -4px;
  }

  .error-title {
    font-family: 'Lato', sans-serif;
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .error-sub {
    font-family: 'Lato', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    opacity: 0.85;
    margin: 0;
    max-width: 400px;
  }

  .error-btn {
    margin-top: 1rem;
    display: inline-block;
    padding: 0.9rem 2.2rem;
    background: #fff;
    color: #000;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }

  .error-btn:hover {
    background: #000;
    color: #fff;
    transform: translateY(-2px);
  }
</style>
