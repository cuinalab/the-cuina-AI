---
import { getCollection, render } from 'astro:content';
import LandingPost from '../../layouts/LandingPost.astro';

export async function getStaticPaths() {
  const allLandings = await getCollection('landings');
  return allLandings.map(landing => ({
    params: { slug: landing.id },
    props:  { landing },
  }));
}

const { landing } = Astro.props;
const { Content }  = await render(landing);

const {
  title           = 'Landing',
  excerpt         = '',
  metaDescription = '',
  image,
  imageAlt        = '',
  cta             = 'Solicitar información',
  ctaUrl          = '#contacto',
  category        = '',
  tags            = [],
  date            = '',
  dateModified,
  authorityBadges = [],
  bannerTitle,
  bannerBody,
  faqs            = [],
  schemaType,
} = landing.data;
---

<LandingPost
  title={title}
  excerpt={excerpt}
  metaDescription={metaDescription}
  image={image}
  imageAlt={imageAlt}
  ctaPrimary={cta}
  ctaPrimaryUrl={ctaUrl}
  category={category}
  tags={tags}
  date={date}
  dateModified={dateModified}
  authorityBadges={authorityBadges}
  bannerTitle={bannerTitle}
  bannerBody={bannerBody}
  faqs={faqs}
  schemaType={schemaType}
>
  <Content />
</LandingPost>
