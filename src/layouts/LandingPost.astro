---
import Base from './Base.astro';
import '../styles/blog.css';

interface Props {
  title:            string;
  excerpt?:         string;
  metaDescription?: string;
  image?:           string;
  imageAlt?:        string;
  cta?:             string;
  ctaUrl?:          string;
  category?:        string;
  tags?:            string[];
  date?:            string;
}

const {
  title,
  excerpt         = '',
  metaDescription = excerpt,
  image,
  imageAlt        = '',
  cta             = 'Solicitar información',
  ctaUrl          = '/contacto',
  category        = '',
  tags            = [],
  date            = '',
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": metaDescription || excerpt,
};
---

<Base title={`${title} · The Cuina AI`} description={metaDescription || excerpt} schema={schema}>

  <div class="post-page">

    <!-- HERO -->
    <header class="post-hero">
      {category && <span class="post-tag">{category}</span>}
      <h1>{title}</h1>
      {excerpt && <p class="post-excerpt">{excerpt}</p>}
      {cta && (
        <a href={ctaUrl} class="landing-cta-btn">{cta}</a>
      )}
    </header>

    <!-- IMAGEN -->
    {image && (
      <div class="post-cover">
        <img src={image} alt={imageAlt} class="post-cover-img" loading="lazy" />
      </div>
    )}

    <!-- CONTENIDO MARKDOWN -->
    <article class="post-body">
      <slot />
    </article>

    <!-- CTA FINAL -->
    {cta && (
  <!-- CTA BANNER -->
<div class="cta-banner">

  <div class="container">
    <h2>¿Impulsamos la IA en tu negocio?</h2>
    <p>En solo 30 días podrías tener una solución de IA funcionando y con métricas reales.<br><strong>Agenda una llamada gratuita</strong> y te enseñamos el mejor camino para tu negocio.</p>
    <a href="#contacto" class="btn-cta">Contacta con nosotros →</a>
  </div>
</div>
    )}

  </div>

  <!-- CTA CONTACTO -->
  <section class="contacto" id="contacto">
    <div class="container">
      <div class="contacto-grid fade-in">
        <div class="contacto-info">
          <div class="section-label">Contacto</div>
          <h2 class="section-title">¿Impulsamos la IA en tu <span style="color:var(--accent)">negocio</span>?</h2>
          <p>Si deseas impulsar tu negocio con IA, completa el formulario y conecta con nosotros. ¡Te acompañamos a dar el siguiente paso!</p>
          <ul class="contacto-features">
            <li>Consultoría de IA 100% personalizada</li>
            <li>Adaptación a los objetivos del negocio</li>
            <li>Enfoque estratégico para maximizar el ROI</li>
          </ul>
        </div>
        <form class="form-grid" id="contact-form-landing">
          <div class="form-row">
            <div class="form-group">
              <label>Nombre *</label>
              <input type="text" name="name" placeholder="Tu nombre" required>
            </div>
            <div class="form-group">
              <label>Organización *</label>
              <input type="text" name="company" placeholder="Tu empresa" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Cargo *</label>
              <input type="text" name="role" placeholder="Tu cargo" required>
            </div>
            <div class="form-group">
              <label>Correo *</label>
              <input type="email" name="email" placeholder="tu@empresa.com" required>
            </div>
          </div>
          <div class="form-group">
            <label>Tu consulta</label>
            <textarea name="message" placeholder="Cuéntanos tu caso..."></textarea>
          </div>
          <input type="text" name="website" style="display:none">
          <button type="submit" class="btn-cta" style="width:100%;justify-content:center;padding:14px;">
            Solicitar llamada
          </button>
        </form>
      </div>
    </div>
  </section>

  <style>
    .landing-cta-btn {
      display: inline-block;
      margin-top: 1.5rem;
      padding: 0.85rem 2rem;
      background: var(--color-accent, #000);
      color: #fff;
      border-radius: 6px;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .landing-cta-btn:hover {
      opacity: 0.85;
    }

.cta-banner { background: #fff; padding: 80px 0; text-align: center; }
.cta-banner .container {
  background: linear-gradient(135deg, rgba(0,51,39,.88), rgba(0,9,7,.68));
  border: 1px solid var(--nav-border);
  box-shadow: var(--shadow-md);
  border-radius: var(--radius-lg);
  padding-top: 72px;
  padding-bottom: 72px;
}
.cta-banner h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: var(--weight-black); letter-spacing: -.025em; margin-bottom: var(--space-sm); }
.cta-banner p { color: var(--text); margin-bottom: 36px; font-size: var(--text-md); font-weight: var(--weight-regular); }

  </style>

  <script>
    document.getElementById("contact-form-landing").addEventListener("submit", async function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      if (formData.get("website")) return;
      const payload = {
        name: formData.get("name"),
        company: formData.get("company"),
        role: formData.get("role"),
        email: formData.get("email"),
        message: formData.get("message"),
        page: window.location.href,
        submittedAt: new Date().toISOString()
      };
      try {
        const response = await fetch("https://n8n.srv1124642.hstgr.cloud/webhook/lead-thecuina", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });
        if (response.ok) {
          alert("Gracias. Hemos recibido tu solicitud.");
          this.reset();
        } else {
          alert("Ha habido un error. Por favor, inténtalo de nuevo.");
        }
      } catch {
        alert("Ha habido un error de conexión. Por favor, inténtalo de nuevo.");
      }
    });
  </script>

</Base>
