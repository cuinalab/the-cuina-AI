---
// src/layouts/BlogPost.astro
import Base from './Base.astro';
import '../styles/blog.css';


interface Props {
  title:        string;
  excerpt:      string;
  category:     string;
  date:         string;
  readTime:     string;
  author?:      string;
  authorImage?: string;   // ruta desde public/, ej: 
  tags?:        string[];
  image?:       string;
  imageAlt?:    string;
}


const {
  title,
  excerpt,
  category,
  date,
  readTime,
  author      = 'The Cuina AI',
  authorImage = '',
  tags        = [],
  image,
  imageAlt    = '',
} = Astro.props;

function formatDate(d: string) {
  const months = ['enero','febrero','marzo','abril','mayo','junio',
                  'julio','agosto','septiembre','octubre','noviembre','diciembre'];
  try {
    const [y, m, day] = d.split('-').map(Number);
    return `${day} de ${months[m - 1]} de ${y}`;
  } catch { return d; }
}

const dateDisplay = formatDate(date);

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": excerpt,
  "datePublished": date,
  "author": { "@type": "Organization", "name": author },
  "publisher": { "@id": "https://www.thecuina.com/#sobre-the-cuina" }
};
---

<Base title={`${title} · The Cuina AI`} description={excerpt} schema={schema}>

<div class="post-page">

  <div class="read-progress" id="read-progress"></div>

  <!-- HERO -->
  <header class="post-hero">
    <div class="post-meta">
      <span class="post-tag">{category}</span>
      <span class="post-chip">{dateDisplay}</span>
      <span class="post-chip">{readTime} min de lectura</span>
    </div>
    <h1>{title}</h1>
    <p class="post-excerpt">{excerpt}</p>
  </header>

  <!-- IMAGEN DESTACADA -->
  {image && (
    <div class="post-cover">
      <img src={image} alt={imageAlt} class="post-cover-img" loading="lazy" />
    </div>
  )}

  <!-- CONTENIDO -->
  <article class="post-body">
    <slot />

    <!-- TAGS -->
    {tags.length > 0 && (
      <div class="tags-row">
        {tags.map(t => <span class="post-tag-item">{t}</span>)}
      </div>
    )}

    <!-- COMPARTIR -->
    <div class="share-row">
      <span class="share-label">Compartir</span>
      <a class="share-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(typeof window !== 'undefined' ? window.location.href : '')}`} target="_blank" rel="noopener">Twitter / X</a>
      <a class="share-btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(typeof window !== 'undefined' ? window.location.href : '')}`} target="_blank" rel="noopener">LinkedIn</a>
    </div>

    <!-- AUTOR -->
    <div class="author-box">
      <div class="author-av">
        {authorImage
          ? <img src={authorImage} alt={author} class="author-img" />
          : <span>💡</span>
        }
      </div>
      <div>
        <div class="author-name">{author}</div>
        <div class="author-bio">The Cuina AI es la consultora estratégica de IA que acompaña a PYMEs a adoptar inteligencia artificial con impacto real en negocio.</div>
      </div>
    </div>
  </article>

  <!-- ARTÍCULOS RELACIONADOS -->
  <div class="related">
    <div class="related-inner">
      <span class="tag">Sigue leyendo</span>
      <h3>Artículos relacionados</h3>
      <div class="related-grid" id="related-grid">
        <!-- Cargado por JS desde /blog-posts.json -->
      </div>
    </div>
  </div>

  <!-- VOLVER -->
  <div class="back-section">
    <a href="/blog" class="back-link">← Volver al blog</a>
  </div>

</div>

<script>
  // Progress bar
  window.addEventListener('scroll', () => {
    const d = document.documentElement;
    const progress = d.scrollTop / (d.scrollHeight - d.clientHeight);
    const bar = document.getElementById('read-progress');
    if (bar) bar.style.width = (progress * 100) + '%';
  });

  // Load related posts
  async function loadRelated() {
    try {
      const res = await fetch('/blog-posts.json');
      if (!res.ok) return;
      const posts = await res.json();
      const slug = window.location.pathname.split('/').pop();
      const others = posts.filter((p: any) => p.slug !== slug).slice(0, 2);
      const grid = document.getElementById('related-grid');
      if (!grid || others.length === 0) return;
      grid.innerHTML = others.map((p: any) => `
        <a class="rel-card" href="${p.url}">
          <span class="post-tag">${p.category || 'Article'}</span>
          <h4>${p.title}</h4>
        </a>
      `).join('');
    } catch {}
  }
  loadRelated();
</script>

</Base>
